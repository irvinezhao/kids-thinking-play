{
  "name": "kids-thinking-play",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:android:web": "VITE_CAPACITOR=1 npm run build",
    "build:apk": "npm run build:android:web && npx cap sync android && cd android && ./gradlew assembleRelease",
    "build:apk:debug": "npm run build:android:web && npx cap sync android && cd android && ./gradlew assembleDebug",
    "lint": "oxlint",
    "preview": "vite preview",
    "voice:minimax:test": "python3 scripts/generate_minimax_voice_pack.py",
    "voice:minimax:all": "python3 scripts/generate_minimax_voice_pack.py --mode all"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "oxlint": "^1.69.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.0"
  }
}
